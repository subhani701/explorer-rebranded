# =============================================================================
# FRONTEND CONFIG  (Blockscout frontend fork — brand values come from brand.env)
# Copy to ../config/frontend.env and fill real values.
# The NEXT_PUBLIC_* values below are wired from brand.env at compose time; keep
# them in sync via `make render-frontend-env` (see Makefile).
# =============================================================================

# --- Hosts (local dev defaults; change for deployment) ---------------------
NEXT_PUBLIC_API_HOST=localhost
NEXT_PUBLIC_API_PROTOCOL=http
NEXT_PUBLIC_API_PORT=4000
NEXT_PUBLIC_APP_HOST=localhost
NEXT_PUBLIC_APP_PROTOCOL=http
NEXT_PUBLIC_WS_PROTOCOL=ws

# --- Network identity (mirror of brand.env / backend) ----------------------
NEXT_PUBLIC_NETWORK_NAME=${BRAND_NETWORK_NAME}
NEXT_PUBLIC_NETWORK_SHORT_NAME=${BRAND_NETWORK_SHORT_NAME}
NEXT_PUBLIC_NETWORK_ID=${CHAIN_ID}
NEXT_PUBLIC_NETWORK_CURRENCY_NAME=${BRAND_CURRENCY_NAME}
NEXT_PUBLIC_NETWORK_CURRENCY_SYMBOL=${BRAND_CURRENCY_SYMBOL}
NEXT_PUBLIC_NETWORK_CURRENCY_DECIMALS=${BRAND_CURRENCY_DECIMALS}
NEXT_PUBLIC_NETWORK_RPC_URL=

# --- Branding (driven by brand.env) ----------------------------------------
# CRITICAL de-brand flag: removes "Blockscout" from the browser/page title.
NEXT_PUBLIC_PROMOTE_BLOCKSCOUT_IN_TITLE=false
NEXT_PUBLIC_NETWORK_LOGO=${BRAND_LOGO_URL}
NEXT_PUBLIC_NETWORK_LOGO_DARK=${BRAND_LOGO_DARK_URL}
NEXT_PUBLIC_NETWORK_ICON=${BRAND_ICON_URL}
NEXT_PUBLIC_NETWORK_ICON_DARK=${BRAND_ICON_DARK_URL}
NEXT_PUBLIC_FOOTER_LINKS=${BRAND_FOOTER_LINKS_URL}
NEXT_PUBLIC_OG_DESCRIPTION=${BRAND_OG_DESCRIPTION}
# Favicon regenerated at container start by the overlaid generator (local path OK).
FAVICON_MASTER_URL=${BRAND_ICON_URL}
BRAND_NAME=${BRAND_NAME}

# --- Features ---------------------------------------------------------------
NEXT_PUBLIC_API_BASE_PATH=/
NEXT_PUBLIC_IS_TESTNET=false
NEXT_PUBLIC_HOMEPAGE_CHARTS=['daily_txs']
NEXT_PUBLIC_STATS_API_HOST=http://localhost:8080
NEXT_PUBLIC_VISUALIZE_API_HOST=http://localhost:8081
NEXT_PUBLIC_CONTRACT_INFO_API_HOST=http://localhost:4000

# --- Color theme (driven by brand.env) -------------------------------------
NEXT_PUBLIC_COLOR_THEME_DEFAULT=dark
# Custom palette is applied via the forked theme; see frontend rebrand notes.
