# =============================================================================
# BACKEND / INDEXER CONFIG  (Blockscout backend — geth variant)
# Copy to ../config/backend.env and fill real values.
# =============================================================================

# --- Chain identity ---------------------------------------------------------
CHAIN_ID=                       # e.g. 1337  (your private network id)
NETWORK_ID=                     # usually same as CHAIN_ID for geth private nets
COIN=ETH
SUBNETWORK="Private Geth"

# --- RPC endpoints (point at your EKS Geth; see DEPLOYMENT.md for access) ----
# For local dev against EKS, port-forward the geth svc and use host.docker.internal.
ETHEREUM_JSONRPC_VARIANT=geth
ETHEREUM_JSONRPC_HTTP_URL=http://host.docker.internal:8545
ETHEREUM_JSONRPC_TRACE_URL=http://host.docker.internal:8545
ETHEREUM_JSONRPC_WS_URL=ws://host.docker.internal:8546

# --- Indexer behavior (full explorer feature set) ---------------------------
INDEXER_DISABLE_INTERNAL_TRANSACTIONS_FETCHER=false   # needs debug API + archive node
INDEXER_DISABLE_PENDING_TRANSACTIONS_FETCHER=false
DISABLE_REALTIME_INDEXER=false
DISABLE_EXCHANGE_RATES=true        # private chain: no market price
# Clique/PoA: Blockscout auto-detects; no extra flag needed for geth variant.

# --- Database ---------------------------------------------------------------
DATABASE_URL=postgresql://blockscout:${POSTGRES_PASSWORD}@db:5432/blockscout
ECTO_USE_SSL=false
POOL_SIZE=40
POOL_SIZE_API=20

# --- App / API --------------------------------------------------------------
SECRET_KEY_BASE=                  # generate: openssl rand -base64 64 | tr -d '\n'
PORT=4000
API_RATE_LIMIT=50
API_RATE_LIMIT_BY_IP=true
MIX_ENV=prod

# --- Microservice integrations ---------------------------------------------
MICROSERVICE_SC_VERIFIER_ENABLED=true
MICROSERVICE_SC_VERIFIER_URL=http://smart-contract-verifier:8050
MICROSERVICE_SC_VERIFIER_TYPE=sc_verifier
MICROSERVICE_VISUALIZE_SOL2UML_ENABLED=true
MICROSERVICE_VISUALIZE_SOL2UML_URL=http://visualizer:8050
MICROSERVICE_SIG_PROVIDER_ENABLED=true
MICROSERVICE_SIG_PROVIDER_URL=http://sig-provider:8050

# --- CORS / frontend hand-off ----------------------------------------------
API_V2_ENABLED=true
