# =============================================================================
# BRAND CONFIGURATION — single source of truth for all visible explorer branding
# =============================================================================
# Copy to ../config/brand.env and fill in real values. Every brand-related value
# in the frontend (name, colors, logo, footer, meta titles) is driven from here.
# No brand strings should be hardcoded anywhere else.
#
# After changing this file: `make rebuild-frontend` (rebuilds the custom image so
# build-time values like favicon/package name are baked in), then `make up`.
# -----------------------------------------------------------------------------

# --- Identity --------------------------------------------------------------
BRAND_NAME="Your Explorer"
BRAND_SHORT_NAME="Explorer"
BRAND_NETWORK_NAME="Private Geth Network"
BRAND_NETWORK_SHORT_NAME="Geth"
BRAND_CURRENCY_NAME="Ether"
BRAND_CURRENCY_SYMBOL="ETH"
BRAND_CURRENCY_DECIMALS="18"

# --- Browser / SEO metadata -----------------------------------------------
BRAND_META_TITLE="Your Explorer — Private Blockchain Explorer"
BRAND_META_DESCRIPTION="Explore blocks, transactions, tokens and smart contracts on the private network."
BRAND_OG_DESCRIPTION="Independent blockchain explorer for the private network."

# --- Visual assets (place files in frontend/public/assets/, reference by URL) -
# Wide header logo (light/dark) and small square icon (light/dark) + favicon.
BRAND_LOGO_URL="/assets/logo.svg"
BRAND_LOGO_DARK_URL="/assets/logo-dark.svg"
BRAND_ICON_URL="/assets/icon.svg"
BRAND_ICON_DARK_URL="/assets/icon-dark.svg"
BRAND_FAVICON_MASTER_URL="/assets/favicon.svg"

# --- Theme colors (hex) ----------------------------------------------------
BRAND_COLOR_PRIMARY="#2D5BFF"
BRAND_COLOR_SECONDARY="#0B1437"
BRAND_COLOR_ACCENT="#00C2A8"

# --- Footer -----------------------------------------------------------------
# Footer link columns are defined in frontend/public/assets/footer-links.json
# (max 3 columns). The default Blockscout footer column and "Made with
# Blockscout" line are removed in the fork; only your columns render.
BRAND_FOOTER_LINKS_URL="/assets/footer-links.json"
BRAND_FOOTER_COPYRIGHT="© 2026 Your Company. All rights reserved."

# --- Optional external links (leave blank to hide) -------------------------
BRAND_HOMEPAGE_URL=""
BRAND_SUPPORT_URL=""
BRAND_DOCS_URL=""
