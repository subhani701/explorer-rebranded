# =============================================================================
# ORCHESTRATION CONFIG — pinned versions, secrets, ports.
# Copy to .env and fill secrets. Never commit the real .env.
# =============================================================================

# --- Pinned image versions (set explicit tags for reproducible prod deploys) -
BACKEND_VERSION=6.10.1
FRONTEND_VERSION=local
STATS_VERSION=2.7.2
VERIFIER_VERSION=1.9.2
VISUALIZER_VERSION=0.2.0
SIG_PROVIDER_VERSION=1.0.0

# --- Secrets (generate strong values) --------------------------------------
# openssl rand -base64 32
POSTGRES_PASSWORD=
STATS_DB_PASSWORD=

# --- Ports ------------------------------------------------------------------
PROXY_HTTP_PORT=80

# --- Brand passthrough (build args for the frontend image) -----------------
# Mirrored from config/brand.env by `make render`. Do not edit by hand.
BRAND_FAVICON_MASTER_URL=/assets/favicon.svg
